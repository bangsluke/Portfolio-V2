---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { howIDeliverConfig } from '../../../deliveryConfig.js';
import { extractNameFromFilename } from '../../utils/filename-utils';
import {
	getProjectCount,
	getProjectsUsingSkill,
} from '../../utils/project-count-utils';
import Heading from '../ui/Heading.astro';
import SkillPill from '../ui/SkillPill.astro';

const skills = await getCollection('skills');
const projects = await getCollection('projects');
const MAX_VISIBLE_SKILLS = 7;

function hasDeliveryTag(
	skillTags: string[] | undefined,
	cardKey: string
): boolean {
	const key = cardKey.toLowerCase();
	return (skillTags ?? []).some(tag => {
		const normalized = String(tag).toLowerCase();
		return normalized === key || normalized === `portfolio/${key}`;
	});
}

const cardsWithSkills = howIDeliverConfig.cards.map(card => {
	const taggedSkills = skills.filter(skill =>
		hasDeliveryTag(skill.data.tags, card.key)
	);

	const skillsWithMeta = taggedSkills.map(skill => {
		const filename = extractNameFromFilename(skill.id);
		const skillName = skill.data.name ?? filename;
		const description =
			(skill.data as { skillDescription?: string }).skillDescription ?? '';
		const aliasesRaw = (skill.data as { aliases?: unknown }).aliases;
		const aliasesArray = Array.isArray(aliasesRaw)
			? aliasesRaw
			: typeof aliasesRaw === 'string'
				? [aliasesRaw]
				: aliasesRaw && typeof aliasesRaw === 'object'
					? Object.values(aliasesRaw as Record<string, unknown>)
					: [];
		const normalizedAliases = aliasesArray
			.map(alias => String(alias).trim())
			.filter(Boolean);

		const MAX_PILL_LABEL_LENGTH = 23;
		let pillLabel = skillName;
		if (
			pillLabel.length > MAX_PILL_LABEL_LENGTH &&
			normalizedAliases.length > 0
		) {
			const candidates = normalizedAliases.filter(
				alias => alias.length <= MAX_PILL_LABEL_LENGTH
			);
			const best = (
				candidates.length > 0 ? candidates : normalizedAliases
			).sort((a, b) => a.length - b.length)[0];
			if (best) pillLabel = best;
		}

		const count = getProjectCount(skillName, filename, projects);
		const usedProjects = getProjectsUsingSkill(skillName, filename, projects);

		return {
			id: skill.id,
			displayName: skillName,
			pillLabel,
			description,
			count,
			projects: usedProjects,
		};
	});

	skillsWithMeta.sort((a, b) => {
		if (b.count !== a.count) return b.count - a.count;
		return a.displayName.localeCompare(b.displayName);
	});

	return {
		...card,
		skills: skillsWithMeta,
		visibleSkills: skillsWithMeta.slice(0, MAX_VISIBLE_SKILLS),
		hiddenSkills: skillsWithMeta.slice(MAX_VISIBLE_SKILLS),
	};
});
---

<section
	class="main-section pt-8 pb-6 md:pt-12 md:pb-12 overflow-x-hidden"
	id="delivery"
	data-testid="delivery-section">
	<div class="max-w-7xl mx-auto overflow-x-hidden overflow-y-hidden">
		<div class="flex gap-4 items-center justify-center mb-4 md:mb-3">
			<Icon
				class="text-3xl dark:text-white text-blacktext rotate-[-45deg] overflow-visible"
				name="paperplane"
			/>
			<Heading text="How I" textGradient="Deliver" level={2} />
		</div>

		<p
			class="text-center text-colour dark:text-zinc-200 text-base md:text-lg max-w-4xl mx-auto mb-8"
			data-testid="delivery-intro">
			{howIDeliverConfig.introText}
		</p>

		<div
			class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6"
			data-testid="delivery-cards-grid">
			{
				cardsWithSkills.map(card => (
					<article
						class="delivery-card rounded-2xl bg-linear-to-r from-theme-300 dark:from-theme-600 to-theme-200 dark:to-theme-200/8 p-[.2rem] shadow-lg transition-all hover:shadow-[0_20px_50px_var(--color-theme-500-rgba-04)]"
						data-testid={`delivery-card-${card.key}`}>
						<div class="delivery-card-inner h-full rounded-2xl bg-linear-to-tr from-theme-300 to-theme-100 dark:bg-linear-to-r dark:from-theme-900 dark:to-theme-950 p-5 flex flex-col relative overflow-visible">
							<div class="delivery-card-mask pointer-events-none">
								<div class="delivery-card-mask-gradient" />
							</div>
							<div class="flex items-center gap-3 mb-3">
								<div class="rounded-xl bg-zinc-700/80 p-2">
									<Icon
										class="text-xl text-light-theme-accent-400"
										name={card.iconName}
									/>
								</div>
								<h3 class="text-white text-2xl md:text-xl font-bold leading-tight">
									{card.title}
								</h3>
							</div>

							<p class="text-zinc-200 text-base mb-5 leading-7 flex-1">
								{card.description}
							</p>

							<div
								class="flex flex-wrap gap-2"
								data-testid={`delivery-card-skills-${card.key}`}>
								{card.visibleSkills.map((skill, index) => (
									<div
										class="relative skill-tooltip-trigger"
										data-skill-name={skill.displayName}
										data-skill-description={skill.description}
										data-skill-count={skill.count}>
										<SkillPill
											skillName={`${skill.displayName}|${skill.pillLabel}`}
											size="sm"
											variant="theme"
											className="cursor-default"
											projects={projects}
											disableTooltip={true}
										/>
									</div>
								))}
								{card.hiddenSkills.length > 0 && (
									<div class="relative group/tooltip">
										<div class="flex items-center justify-center w-8 h-8 bg-theme-400/20 border border-theme-400/30 rounded-full text-theme-400 hover:bg-theme-400/30 transition-colors duration-200 cursor-help">
											<span class="text-sm font-medium select-none">
												+{card.hiddenSkills.length}
											</span>
										</div>
										<div class="absolute bottom-full left-0 md:left-1/2 md:-translate-x-1/2 mb-2 opacity-0 pointer-events-none group-hover/tooltip:opacity-100 group-hover/tooltip:pointer-events-auto group-active/tooltip:opacity-100 group-active/tooltip:pointer-events-auto transition-opacity duration-200 z-50 w-[500px] max-w-[85vw]">
											<div class="global-tooltip w-full min-w-[20rem] pointer-events-auto">
												<div class="global-tooltip-content">
													<div class="text-xs text-theme-400 font-medium mb-2">
														Additional skills:
													</div>
													<div class="flex flex-wrap gap-2">
														{card.hiddenSkills.map((skill, index) => (
															<div
																class="relative skill-tooltip-trigger"
																data-skill-name={skill.displayName}
																data-skill-description={skill.description}
																data-skill-count={skill.count}>
																<SkillPill
																	skillName={`${skill.displayName}|${skill.pillLabel}`}
																	size="sm"
																	variant="theme"
																	className="cursor-default"
																	projects={projects}
																	disableTooltip={true}
																/>
															</div>
														))}
													</div>
												</div>
											</div>
										</div>
									</div>
								)}
							</div>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<script is:inline>
	if (typeof window !== 'undefined') {
		const mediaQuery = window.matchMedia('(hover: hover) and (pointer: fine)');

		if (mediaQuery.matches) {
			window.addEventListener('DOMContentLoaded', () => {
				const grid = document.querySelector(
					'[data-testid="delivery-cards-grid"]'
				);
				if (!grid) return;

				const cards = Array.from(
					grid.querySelectorAll('[data-testid^="delivery-card-"]')
				);

				cards.forEach(card => {
					const mask = card.querySelector('.delivery-card-mask');
					if (!mask) return;

					card.addEventListener('mousemove', event => {
						const rect = card.getBoundingClientRect();
						const x = event.clientX - rect.left;
						const y = event.clientY - rect.top;

						mask.style.setProperty('--mask-position-x', x + 'px');
						mask.style.setProperty('--mask-position-y', y + 'px');
					});

					card.addEventListener('mouseleave', () => {
						mask.style.setProperty('--mask-position-x', '50%');
						mask.style.setProperty('--mask-position-y', '50%');
					});
				});
			});
		}
	}
</script>
