---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/portfolio/ProjectCard.astro';
import Heading from '../../components/ui/Heading.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { processObsidianLink } from '../../utils/content-processor';
import {
	extractNameFromFilename,
	nameToSlug,
} from '../../utils/filename-utils';

// Get all projects, companies, clients, and educations
const projects = await getCollection('projects');
const companies = await getCollection('companies');
const clients = await getCollection('clients');
const educations = await getCollection('educations');

// Sort projects by portfolioOrder first, then dateStart, then alphabetically
const sortedProjects = projects.sort((a, b) => {
	// Get portfolioOrder values (default to 999 if not set)
	const orderA = a.data.portfolioOrder || 999;
	const orderB = b.data.portfolioOrder || 999;

	// First, sort by portfolioOrder (numerically)
	if (orderA !== orderB) {
		return orderA - orderB;
	}

	// If portfolioOrder is the same, sort by dateStart (chronologically)
	const dateA = a.data.dateStart || new Date(0);
	const dateB = b.data.dateStart || new Date(0);

	const dateAValue =
		dateA instanceof Date ? dateA.getTime() : new Date(dateA).getTime();
	const dateBValue =
		dateB instanceof Date ? dateB.getTime() : new Date(dateB).getTime();

	if (dateAValue !== dateBValue) {
		return dateBValue - dateAValue; // Newest dates first
	}

	// If dates are the same, fallback to alphabetical sorting by slug
	return (a.slug ?? '').localeCompare(b.slug ?? '');
});

// Process projects to add company logos and generate names
const processedProjects = sortedProjects.map(project => {
	let companyLogoURL: string | null = null;

	// Use name from frontmatter (generated by sync process)
	const projectName = project.data.name;

	// If project has linkedCompany, find the company or client and get its logoURL
	if (project.data.linkedCompany && project.data.linkedCompany.length > 0) {
		// Get the first linked company and process Obsidian link format
		const linkedCompanyRaw = project.data.linkedCompany[0];
		const linkedCompanyName = processObsidianLink(linkedCompanyRaw);

		// First try to find in companies collection
		const company = companies.find(company => {
			const companyName = extractNameFromFilename(company.id);
			return companyName === linkedCompanyName;
		});

		if (company && company.data.logoURL) {
			companyLogoURL = company.data.logoURL;
		} else {
			// If not found in companies, try clients collection
			const client = clients.find(client => {
				const clientName = extractNameFromFilename(client.id);
				return clientName === linkedCompanyName;
			});

			if (client && client.data.logoURL) {
				companyLogoURL = client.data.logoURL;
			} else {
				// If not found in clients, try educations collection
				const education = educations.find(education => {
					const educationName = extractNameFromFilename(education.id);
					return educationName === linkedCompanyName;
				});

				if (education && education.data.logoURL) {
					companyLogoURL = education.data.logoURL;
				}
			}
		}
	}

	return {
		...project,
		data: {
			...project.data,
			name: projectName,
		},
		companyLogoURL,
	};
});

// Get unique project categories
const projectCategories = Array.from(
	new Set<string>(
		processedProjects
			.map(project => project.data.projectCategory)
			.filter(
				(category): category is string =>
					typeof category === 'string' && category.length > 0
			)
	)
).sort();

// Calculate date range for filter (for input min/max attributes)
const projectDates = processedProjects
	.map(project => {
		const startDate = project.data.dateStart
			? new Date(project.data.dateStart)
			: null;
		const endDate = project.data.dateEnd
			? new Date(project.data.dateEnd)
			: null;
		return { startDate, endDate };
	})
	.filter(dates => dates.startDate || dates.endDate);

const minDate =
	projectDates.length > 0
		? Math.min(
				...projectDates.map(
					d => d.startDate?.getTime() || d.endDate?.getTime() || Date.now()
				)
			)
		: Date.now();
const maxDate =
	projectDates.length > 0
		? Math.max(
				...projectDates.map(
					d => d.endDate?.getTime() || d.startDate?.getTime() || 0
				)
			)
		: Date.now();

const minYear = new Date(minDate).getFullYear();
const maxYear = new Date(maxDate).getFullYear();

const pageTitle = 'Project Gallery - bangsluke Portfolio';
const description = 'Explore all my projects and developments';
const ogimage = {
	url: '/images/siteImage.webp',
	alt: 'Project Gallery - bangsluke Portfolio',
};
---

<Layout pageTitle={pageTitle} description={description} ogimage={ogimage}>
	<div class="min-h-screen">
		<!-- Header Section -->
		<section class="py-8 px-8 max-md:py-4">
			<div class="max-w-7xl mx-auto">
				<!-- Top Back Button -->
				<div class="mb-8 text-center">
					<a
						href="/#projects"
						class="inline-flex items-center text-theme-400 hover:text-theme-300 transition-colors">
						<svg
							class="w-5 h-5 mr-2"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M15 19l-7-7 7-7"></path>
						</svg>
						Back to Projects Section
					</a>
				</div>

				<div class="flex gap-4 items-center justify-center mb-12">
					<Icon class="text-4xl text-theme-400" name="dashboard" />
					<Heading text="Project " textGradient="Gallery" level={1} />
				</div>

				<p
					class="text-center mx-auto text-lg max-xl:text-base max-w-2xl text-colour mb-12 leading-6 font-medium">
					Explore all my <b
						class="bg-linear-to-r from-light-theme-accent-500 to-light-theme-accent-600 dark:from-light-theme-accent-500 dark:to-light-theme-accent-600 text-transparent bg-clip-text"
						>projects and developments</b
					>
				</p>

				<!-- Filter Section -->
				<div
					class="flex flex-col gap-4 mb-8 p-6 bg-white dark:bg-theme-900 rounded-2xl shadow-lg">
					<button
						id="mobileFiltersToggle"
						type="button"
						class="flex items-center justify-between w-full text-white font-semibold">
						<span>Filters and Sorting</span>
						<svg
							id="mobileFiltersArrow"
							class="w-4 h-4 transition-transform"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M6 9l6 6 6-6" />
						</svg>
					</button>

					<div
						id="mobileFiltersContent"
						class="flex flex-col gap-6"
						aria-label="Filters and sorting content">
						<!-- Desktop Layout: All filters in one row -->
						<div class="hidden md:flex items-center justify-between gap-6">
							<!-- Category Filter -->
							<div class="flex items-center gap-4">
								<label
									for="categoryFilter"
									class="text-colour font-medium whitespace-nowrap"
									>Filter by Category:</label
								>
								<select
									id="categoryFilter"
									class="global-element global-form-element">
									<option value="">All Categories</option>
									{
										projectCategories.map(category => (
											<option value={category}>{category}</option>
										))
									}
								</select>
							</div>

							<!-- Date Range Filter -->
							<div class="flex items-center gap-4">
								<label class="text-colour font-medium whitespace-nowrap"
									>Date Range:</label
								>
								<div class="flex items-center gap-2">
									<div class="relative">
										<input
											type="date"
											id="startDateInput"
											min={`${minYear}-01-01`}
											max={`${maxYear}-12-31`}
											class="global-element global-form-element projects-filter-input"
											aria-label="Start Date"
										/>
										<span
											id="startDatePlaceholder"
											aria-hidden="true"
											class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-xs text-slate-200">
											Start Date
										</span>
									</div>
									<span class="text-colour">-</span>
									<div class="relative">
										<input
											type="date"
											id="endDateInput"
											min={`${minYear}-01-01`}
											max={`${maxYear}-12-31`}
											class="global-element global-form-element projects-filter-input"
											aria-label="End Date"
										/>
										<span
											id="endDatePlaceholder"
											aria-hidden="true"
											class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-xs text-slate-200">
											End Date
										</span>
									</div>
								</div>
							</div>

							<!-- Clear Filters Button -->
							<button
								id="clearFilters"
								class="global-element global-button global-clear-button">
								Clear Filters
							</button>

							<!-- Project Count -->
							<div class="text-colour font-medium whitespace-nowrap">
								<span id="projectCount">{processedProjects.length}</span> projects
							</div>
						</div>

						<!-- Desktop Sorting Row -->
						<div class="hidden md:flex items-center gap-3">
							<span class="text-colour font-medium whitespace-nowrap">Sort:</span>
							<div class="flex items-center gap-2">
								<button
									id="sortModeDesktop"
									type="button"
									class="global-element global-button flex items-center gap-2 whitespace-nowrap">
									<svg
										class="w-4 h-4"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M4 6h16M4 12h10M4 18h6" />
									</svg>
									<span id="sortModeLabelDesktop">Sorted by Priority</span>
								</button>
								<button
									id="sortDirectionDesktop"
									type="button"
									class="global-element global-button flex items-center gap-1 whitespace-nowrap">
									<svg
										id="sortDirectionIconDesktop"
										class="w-3 h-3 transition-transform"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M7 11l5-5 5 5" />
									</svg>
										<span id="sortDirectionLabelDesktop">Descending</span>
								</button>
							</div>
						</div>

						<!-- Mobile Layout: Stacked filters -->
						<div class="md:hidden flex flex-col gap-4">
							<!-- Category Filter -->
							<div class="flex flex-col gap-2">
								<label
									for="categoryFilterMobile"
									class="text-colour font-medium projects-filter-label-mobile"
									>Filter by Category:</label
								>
								<select
									id="categoryFilterMobile"
									class="global-element global-form-element projects-filter-input projects-filter-control-text-mobile">
									<option value="">All Categories</option>
									{
										projectCategories.map(category => (
											<option value={category}>{category}</option>
										))
									}
								</select>
							</div>

							<!-- Date Range Filter -->
							<div class="flex flex-col gap-2">
								<label
									class="text-colour font-medium projects-filter-label-mobile"
									>Filter by Date Range:</label
								>
								<div class="flex items-center gap-2">
									<div class="relative flex-1">
										<input
											type="date"
											id="startDateInputMobile"
											min={`${minYear}-01-01`}
											max={`${maxYear}-12-31`}
											class="text-colour flex-1 global-element global-form-element projects-filter-input projects-filter-control-text-mobile min-w-[7rem]"
											aria-label="Start Date"
										/>
										<span
											id="startDatePlaceholderMobile"
											aria-hidden="true"
											class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-xs text-slate-200">
											Start Date
										</span>
									</div>
									<span class="text-colour">-</span>
									<div class="relative flex-1">
										<input
											type="date"
											id="endDateInputMobile"
											min={`${minYear}-01-01`}
											max={`${maxYear}-12-31`}
											class="text-colour flex-1 global-element global-form-element projects-filter-input projects-filter-control-text-mobile min-w-[7rem]"
											aria-label="End Date"
										/>
										<span
											id="endDatePlaceholderMobile"
											aria-hidden="true"
											class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-xs text-slate-200">
											End Date
										</span>
									</div>
								</div>
							</div>

							<!-- Clear Filters Button -->
							<button
								id="clearFiltersMobile"
								class="global-element global-button global-clear-button projects-filter-control-text-mobile">
								Clear Filters
							</button>

							<!-- Project Count -->
							<div
								class="text-colour font-medium text-center projects-filter-count-mobile">
								<span id="projectCountMobile">{processedProjects.length}</span> projects
							</div>

							<!-- Sorting Controls (Mobile) -->
							<div class="flex items-center justify-between gap-2">
								<span
									class="text-colour font-medium projects-filter-label-mobile"
									>Sort:</span
								>
								<div class="flex items-center justify-end gap-2">
									<button
										id="sortModeMobile"
										type="button"
										class="global-element global-button flex items-center gap-2 whitespace-nowrap projects-filter-control-text-mobile">
										<svg
											class="w-4 h-4"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M4 6h16M4 12h10M4 18h6" />
										</svg>
										<span id="sortModeLabelMobile">Sorted by Priority</span>
									</button>
									<button
										id="sortDirectionMobile"
										type="button"
										class="global-element global-button flex items-center gap-1 whitespace-nowrap projects-filter-control-text-mobile">
										<svg
											id="sortDirectionIconMobile"
											class="w-3 h-3 transition-transform"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M7 11l5-5 5 5" />
										</svg>
										<span id="sortDirectionLabelMobile">Descending</span>
									</button>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Projects Grid Section -->
		<section class="py-8 px-8 max-md:py-4 mb-4">
			<div class="max-w-7xl mx-auto">
				<div
					id="projectsGrid"
					class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
					{
						processedProjects.map(project => {
							const startDate = project.data.dateStart
								? new Date(project.data.dateStart)
								: null;
							const endDate = project.data.dateEnd
								? new Date(project.data.dateEnd)
								: null;

							return (
								<div
									data-category={project.data.projectCategory || ''}
									data-start-date={
										startDate ? startDate.toISOString().split('T')[0] : ''
									}
									data-end-date={
										endDate ? endDate.toISOString().split('T')[0] : ''
									}
									data-portfolio-order={project.data.portfolioOrder || 999}>
									<ProjectCard
										name={
											project.data.name ?? extractNameFromFilename(project.id)
										}
										imageURL={project.data.imageURL}
										technologies={project.data.technologies}
										shortDescription={project.data.shortDescription}
										slug={nameToSlug(extractNameFromFilename(project.id))}
										companyLogoURL={project.companyLogoURL}
										linkedCompany={project.data.linkedCompany}
										projects={projects}
										dateStart={project.data.dateStart}
										dateEnd={project.data.dateEnd}
									/>
								</div>
							);
						})
					}
				</div>
			</div>
		</section>

		<!-- Bottom Back Button -->
		<section class="py-8 px-8 max-md:py-4">
			<div class="max-w-7xl mx-auto">
				<div class="text-center">
					<a
						href="/#projects"
						class="inline-flex items-center text-theme-400 hover:text-theme-300 transition-colors">
						<svg
							class="w-5 h-5 mr-2"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M15 19l-7-7 7-7"></path>
						</svg>
						Back to Projects Section
					</a>
				</div>
			</div>
		</section>
	</div>

	<script>
		// Get URL parameters
		const urlParams = new URLSearchParams(window.location.search);
		const categoryParam = urlParams.get('category');

		// Filter elements (Desktop)
		const categoryFilter = document.getElementById(
			'categoryFilter'
		) as HTMLSelectElement;
		const projectsGrid = document.getElementById(
			'projectsGrid'
		) as HTMLElement | null;
		const projectCards = document.querySelectorAll(
			'#projectsGrid > div'
		) as NodeListOf<HTMLElement>;
		const projectWrappers: HTMLElement[] = Array.from(projectCards);
		const projectCount = document.getElementById('projectCount');
		const startDateInput = document.getElementById(
			'startDateInput'
		) as HTMLInputElement;
		const endDateInput = document.getElementById(
			'endDateInput'
		) as HTMLInputElement;
		const clearFilters = document.getElementById(
			'clearFilters'
		) as HTMLButtonElement;

		// Filter elements (Mobile)
		const categoryFilterMobile = document.getElementById(
			'categoryFilterMobile'
		) as HTMLSelectElement;
		const projectCountMobile = document.getElementById('projectCountMobile');
		const startDateInputMobile = document.getElementById(
			'startDateInputMobile'
		) as HTMLInputElement;
		const endDateInputMobile = document.getElementById(
			'endDateInputMobile'
		) as HTMLInputElement;
		const clearFiltersMobile = document.getElementById(
			'clearFiltersMobile'
		) as HTMLButtonElement;

		// Mobile filter collapse elements
		const mobileFiltersToggle = document.getElementById(
			'mobileFiltersToggle'
		) as HTMLButtonElement | null;
		const mobileFiltersContent = document.getElementById(
			'mobileFiltersContent'
		) as HTMLElement | null;
		const mobileFiltersArrow = document.getElementById(
			'mobileFiltersArrow'
		) as SVGSVGElement | null;

		// Sorting controls
		const sortModeDesktop = document.getElementById(
			'sortModeDesktop'
		) as HTMLButtonElement | null;
		const sortDirectionDesktop = document.getElementById(
			'sortDirectionDesktop'
		) as HTMLButtonElement | null;
		const sortModeLabelDesktop = document.getElementById(
			'sortModeLabelDesktop'
		) as HTMLSpanElement | null;
		const sortDirectionLabelDesktop = document.getElementById(
			'sortDirectionLabelDesktop'
		) as HTMLSpanElement | null;
		const sortDirectionIconDesktop = document.getElementById(
			'sortDirectionIconDesktop'
		) as SVGSVGElement | null;

		const sortModeMobile = document.getElementById(
			'sortModeMobile'
		) as HTMLButtonElement | null;
		const sortDirectionMobile = document.getElementById(
			'sortDirectionMobile'
		) as HTMLButtonElement | null;
		const sortModeLabelMobile = document.getElementById(
			'sortModeLabelMobile'
		) as HTMLSpanElement | null;
		const sortDirectionLabelMobile = document.getElementById(
			'sortDirectionLabelMobile'
		) as HTMLSpanElement | null;
		const sortDirectionIconMobile = document.getElementById(
			'sortDirectionIconMobile'
		) as SVGSVGElement | null;

		// Date placeholder overlays
		const startDatePlaceholder = document.getElementById(
			'startDatePlaceholder'
		) as HTMLSpanElement | null;
		const endDatePlaceholder = document.getElementById(
			'endDatePlaceholder'
		) as HTMLSpanElement | null;
		const startDatePlaceholderMobile = document.getElementById(
			'startDatePlaceholderMobile'
		) as HTMLSpanElement | null;
		const endDatePlaceholderMobile = document.getElementById(
			'endDatePlaceholderMobile'
		) as HTMLSpanElement | null;

		// Pre-fill category filter from URL parameter (both desktop and mobile)
		if (categoryParam) {
			if (categoryFilter) categoryFilter.value = categoryParam;
			if (categoryFilterMobile) categoryFilterMobile.value = categoryParam;
		}

		type SortMode = 'priority' | 'startDate' | 'endDate';
		type SortDirection = 'asc' | 'desc';

		let currentSortMode: SortMode = 'priority';
		let currentSortDirection: SortDirection = 'desc';

		function updateSortButtonLabels() {
			const modeLabel =
				currentSortMode === 'priority'
					? 'Sorted by Priority'
					: currentSortMode === 'startDate'
						? 'Sorted by Start Date'
						: 'Sorted by End Date';

			if (sortModeLabelDesktop) sortModeLabelDesktop.textContent = modeLabel;
			if (sortModeLabelMobile) sortModeLabelMobile.textContent = modeLabel;

			const directionLabel =
				currentSortDirection === 'asc' ? 'Ascending' : 'Descending';

			if (sortDirectionLabelDesktop)
				sortDirectionLabelDesktop.textContent = directionLabel;
			if (sortDirectionLabelMobile)
				sortDirectionLabelMobile.textContent = directionLabel;

			// Rotate direction icons based on direction (up for ascending, down for descending)
			const rotation = currentSortDirection === 'desc' ? 'rotate-180' : '';
			[
				sortDirectionIconDesktop,
				sortDirectionIconMobile,
			].forEach(icon => {
				if (!icon) return;
				icon.classList.remove('rotate-180');
				if (rotation) {
					icon.classList.add(rotation);
				}
			});
		}

		function getDateFromDataset(
			element: HTMLElement,
			key: 'startDate' | 'endDate'
		): Date | null {
			const value =
				key === 'startDate'
					? element.dataset.startDate
					: element.dataset.endDate;
			if (!value) return null;
			const date = new Date(value);
			return Number.isNaN(date.getTime()) ? null : date;
		}

		function sortProjects() {
			if (!projectsGrid || projectWrappers.length === 0) return;

			const sorted = [...projectWrappers].sort((a, b) => {
				const orderA = Number(a.dataset.portfolioOrder || '999');
				const orderB = Number(b.dataset.portfolioOrder || '999');

				if (currentSortMode === 'priority') {
					const multiplier = currentSortDirection === 'asc' ? 1 : -1;
					if (orderA !== orderB) {
						return (orderA - orderB) * multiplier;
					}

					// Fallback to start date (newest first) similar to server-side logic
					const startA =
						getDateFromDataset(a, 'startDate') ||
						getDateFromDataset(a, 'endDate') ||
						new Date(0);
					const startB =
						getDateFromDataset(b, 'startDate') ||
						getDateFromDataset(b, 'endDate') ||
						new Date(0);

					return startB.getTime() - startA.getTime();
				}

				const key = currentSortMode === 'startDate' ? 'startDate' : 'endDate';

				const aPrimary =
					getDateFromDataset(a, key) ||
					getDateFromDataset(a, key === 'startDate' ? 'endDate' : 'startDate') ||
					new Date(0);
				const bPrimary =
					getDateFromDataset(b, key) ||
					getDateFromDataset(b, key === 'startDate' ? 'endDate' : 'startDate') ||
					new Date(0);

				const multiplier = currentSortDirection === 'asc' ? 1 : -1;
				if (aPrimary.getTime() !== bPrimary.getTime()) {
					return (aPrimary.getTime() - bPrimary.getTime()) * multiplier;
				}

				// Tie-breaker: portfolio order then start date (newest first)
				if (orderA !== orderB) {
					return orderA - orderB;
				}

				const startA =
					getDateFromDataset(a, 'startDate') ||
					getDateFromDataset(a, 'endDate') ||
					new Date(0);
				const startB =
					getDateFromDataset(b, 'startDate') ||
					getDateFromDataset(b, 'endDate') ||
					new Date(0);

				return startB.getTime() - startA.getTime();
			});

			sorted.forEach(wrapper => {
				projectsGrid.appendChild(wrapper);
			});
		}

		function handleSortModeToggle() {
			const modes: SortMode[] = ['priority', 'startDate', 'endDate'];
			const currentIndex = modes.indexOf(currentSortMode);
			currentSortMode = modes[(currentIndex + 1) % modes.length];

			// When switching modes, default directions:
			// - Priority: descending (higher-priority first)
			// - Date modes: descending (newest first)
			if (currentSortMode === 'startDate' || currentSortMode === 'endDate') {
				currentSortDirection = 'desc';
			} else {
				currentSortDirection = 'desc';
			}

			updateSortButtonLabels();
			sortProjects();
			filterProjects();
		}

		function handleSortDirectionToggle() {
			currentSortDirection = currentSortDirection === 'asc' ? 'desc' : 'asc';
			updateSortButtonLabels();
			sortProjects();
			filterProjects();
		}

		function syncDatePlaceholder(
			input: HTMLInputElement | null,
			placeholder: HTMLSpanElement | null
		) {
			if (!input || !placeholder) return;
			const hasValue = !!input.value;
			if (hasValue) {
				placeholder.style.display = 'none';
				input.classList.add('has-value');
			} else {
				placeholder.style.display = 'flex';
				input.classList.remove('has-value');
			}
		}

		function clearAllFilters() {
			// Clear desktop filters
			if (categoryFilter) categoryFilter.value = '';
			if (startDateInput) startDateInput.value = '';
			if (endDateInput) endDateInput.value = '';

			// Clear mobile filters
			if (categoryFilterMobile) categoryFilterMobile.value = '';
			if (startDateInputMobile) startDateInputMobile.value = '';
			if (endDateInputMobile) endDateInputMobile.value = '';

			// Re-filter
			filterProjects();
		}

		function filterProjects() {
			// Get values from desktop or mobile inputs (whichever is visible)
			const selectedCategory =
				categoryFilter?.value || categoryFilterMobile?.value || '';
			const startDate =
				startDateInput?.value || startDateInputMobile?.value
					? new Date(startDateInput?.value || startDateInputMobile?.value || '')
					: null;
			const endDate =
				endDateInput?.value || endDateInputMobile?.value
					? new Date(endDateInput?.value || endDateInputMobile?.value || '')
					: null;

			let visibleCount = 0;

			projectCards.forEach(cardWrapper => {
				const cardCategory = cardWrapper.dataset.category;
				const cardStartDate = cardWrapper.dataset.startDate
					? new Date(cardWrapper.dataset.startDate)
					: null;
				const cardEndDate = cardWrapper.dataset.endDate
					? new Date(cardWrapper.dataset.endDate)
					: null;

				const categoryMatch =
					!selectedCategory || cardCategory === selectedCategory;

				// Improved date filtering logic
				let dateMatch = true;
				if (startDate || endDate) {
					// Get the effective project start and end dates
					const projectStart = cardStartDate || cardEndDate || new Date(0);
					const projectEnd =
						cardEndDate || cardStartDate || new Date(9999, 11, 31);

					if (startDate && endDate) {
						// Both start and end dates are set - check for overlap
						// Project overlaps with filter range if:
						// - Project starts before filter ends AND project ends after filter starts
						dateMatch = projectStart <= endDate && projectEnd >= startDate;
					} else if (startDate) {
						// Only start date filter - show projects that end on or after the start date
						dateMatch = projectEnd >= startDate;
					} else if (endDate) {
						// Only end date filter - show projects that start on or before the end date
						dateMatch = projectStart <= endDate;
					}
				}

				const shouldShow = categoryMatch && dateMatch;

				if (shouldShow) {
					cardWrapper.style.display = 'block';
					visibleCount++;
				} else {
					cardWrapper.style.display = 'none';
				}
			});

			// Update project count (both desktop and mobile)
			if (projectCount) projectCount.textContent = visibleCount.toString();
			if (projectCountMobile)
				projectCountMobile.textContent = visibleCount.toString();
		}

		// Add event listeners for desktop
		if (categoryFilter) {
			categoryFilter.addEventListener('change', filterProjects);
		}
		if (startDateInput) {
			startDateInput.addEventListener('input', filterProjects);
		}
		if (endDateInput) {
			endDateInput.addEventListener('input', filterProjects);
		}
		if (clearFilters) {
			clearFilters.addEventListener('click', clearAllFilters);
		}

		// Add event listeners for mobile
		if (categoryFilterMobile) {
			categoryFilterMobile.addEventListener('change', filterProjects);
		}
		if (startDateInputMobile) {
			startDateInputMobile.addEventListener('input', filterProjects);
		}
		if (endDateInputMobile) {
			endDateInputMobile.addEventListener('input', filterProjects);
		}
		if (clearFiltersMobile) {
			clearFiltersMobile.addEventListener('click', clearAllFilters);
		}

		// Mobile filter collapse toggle
		if (mobileFiltersToggle && mobileFiltersContent) {
			const isMobileInitial = window.matchMedia('(max-width: 767px)').matches;

			// Only start collapsed on small screens; keep expanded on desktop
			if (isMobileInitial) {
				mobileFiltersContent.classList.add('hidden');
				mobileFiltersToggle.setAttribute('aria-expanded', 'false');
			} else {
				mobileFiltersContent.classList.remove('hidden');
				mobileFiltersToggle.setAttribute('aria-expanded', 'true');
			}
			mobileFiltersToggle.setAttribute(
				'aria-controls',
				'mobileFiltersContent'
			);

			mobileFiltersToggle.addEventListener('click', () => {
				const isMobileNow = window.matchMedia('(max-width: 767px)').matches;
				if (!isMobileNow) {
					// On desktop, keep content always visible and ignore toggle for layout stability
					mobileFiltersContent.classList.remove('hidden');
					mobileFiltersToggle.setAttribute('aria-expanded', 'true');
					return;
				}

				const isExpanded =
					mobileFiltersToggle.getAttribute('aria-expanded') === 'true';
				const nextExpanded = !isExpanded;
				mobileFiltersToggle.setAttribute(
					'aria-expanded',
					nextExpanded ? 'true' : 'false'
				);

				if (nextExpanded) {
					mobileFiltersContent.classList.remove('hidden');
				} else {
					mobileFiltersContent.classList.add('hidden');
				}

				if (mobileFiltersArrow) {
					if (nextExpanded) {
						mobileFiltersArrow.classList.add('rotate-180');
					} else {
						mobileFiltersArrow.classList.remove('rotate-180');
					}
				}
			});
		}

		// Sorting controls
		if (sortModeDesktop) {
			sortModeDesktop.addEventListener('click', handleSortModeToggle);
		}
		if (sortModeMobile) {
			sortModeMobile.addEventListener('click', handleSortModeToggle);
		}
		if (sortDirectionDesktop) {
			sortDirectionDesktop.addEventListener('click', handleSortDirectionToggle);
		}
		if (sortDirectionMobile) {
			sortDirectionMobile.addEventListener('click', handleSortDirectionToggle);
		}

		// Date placeholder sync
		[
			[startDateInput, startDatePlaceholder],
			[endDateInput, endDatePlaceholder],
			[startDateInputMobile, startDatePlaceholderMobile],
			[endDateInputMobile, endDatePlaceholderMobile],
		].forEach(([input, placeholder]) => {
			const htmlInput = input as HTMLInputElement | null;
			const htmlPlaceholder = placeholder as HTMLSpanElement | null;
			if (!htmlInput || !htmlPlaceholder) return;

			syncDatePlaceholder(htmlInput, htmlPlaceholder);

			['input', 'change', 'blur'].forEach(eventName => {
				htmlInput.addEventListener(eventName, () =>
					syncDatePlaceholder(htmlInput, htmlPlaceholder)
				);
			});
		});

		// Initialize sort labels and project order, then filters on page load
		updateSortButtonLabels();
		sortProjects();

		// Initialize filters on page load
		filterProjects();
	</script>
</Layout>
