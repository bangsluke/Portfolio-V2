---
// @ts-expect-error - AstroError is not typed
import { AstroError } from 'astro/errors';

const { items = [] }: { items: (keyof typeof menu)[] } = Astro.props as {
	items: (keyof typeof menu)[];
};

const menu = {
	// blog: {
	//   name: "Blog",
	//   path: "/blog/",
	//   dropdown: [
	//     { name: "All Posts", path: "/blog/posts/" },
	//   ]
	// },
	home: { name: 'Home', path: '/#home' },
	projects: { name: 'Projects', path: '/#projects' },
	delivery: { name: 'Delivery', path: '/#delivery' },
	skills: { name: 'Skills', path: '/#skills' },
	experience: { name: 'Experience', path: '/#experience' },
	clients: { name: 'Clients', path: '/#clients' },
	education: { name: 'Education', path: '/#education' },
	references: { name: 'References', path: '/#references' },
	about: { name: 'About Me', path: '/about-me' },
};

// Common base classes
const baseClasses = {
	nav: 'nav-links flex w-full justify-center gap-4 max-md:gap-3 max-md:py-6',
	link: 'px-2 py-2 transition-all hover:text-theme-300 max-md:mx-auto max-md:w-full max-md:px-6 max-md:py-2 ',
	dropdown: 'relative group flex items-center',
	dropdownMenu:
		'absolute left-0 top-full hidden group-hover:block bg-white dark:bg-zinc-800 shadow-lg rounded-md py-2 min-w-[200px] z-50',
	dropdownItem:
		'block px-4 py-2 text-sm hover:bg-theme-100 dark:hover:bg-zinc-700 transition-colors',
} as const;
---

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const isHome = window.location.pathname === '/';

		// Classes for link states
		const linkClasses = {
			active: ['text-theme-400', 'dark:text-theme-400', 'font-bold'],
			inactive: ['dark:text-zinc-300', 'text-blacktext'],
		};

		function toggleLinkClasses(link: Element, isActive: boolean) {
			if (isActive) {
				link.classList.add(...linkClasses.active);
				link.classList.remove(...linkClasses.inactive);
				link.setAttribute('aria-current', 'page');
			} else {
				link.classList.remove(...linkClasses.active);
				link.classList.add(...linkClasses.inactive);
				link.removeAttribute('aria-current');
			}
		}

		function normalizePathname(pathname: string): string {
			return pathname.replace(/\/$/, '') || '/';
		}

		function normalizeLinkPath(path: string | null): string {
			if (!path) return '';
			// Hash links (e.g. /#skills) stay as-is; strip trailing slash from path-only links
			return path.startsWith('/#') ? path : path.replace(/\/$/, '') || path;
		}

		function updateActiveLink() {
			const pathname = window.location.pathname;
			const hash = window.location.hash || '';
			const currentPathNorm = normalizePathname(pathname);
			// On home with no hash, treat as #home so the Home nav item highlights
			const currentFull =
				currentPathNorm === '/' && !hash
					? '/#home'
					: currentPathNorm + hash;

			document.querySelectorAll('nav a').forEach(link => {
				const path = link.getAttribute('data-path');
				const pathNorm = normalizeLinkPath(path);
				toggleLinkClasses(link, pathNorm === currentFull);
			});
		}

		function setupScrollSpy() {
			if (!isHome) return;

			const sections = document.querySelectorAll('section[id]');
			const navLinks = document.querySelectorAll('nav a');

			const observerOptions = {
				root: null,
				rootMargin: '-50% 0px',
				threshold: 0,
			};

			const observer = new IntersectionObserver(entries => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						const sectionId = entry.target.getAttribute('id');
						if (sectionId) {
							navLinks.forEach(link => {
								const path = link.getAttribute('data-path');
								toggleLinkClasses(link, path === `/#${sectionId}`);
							});
						}
					}
				});
			}, observerOptions);

			sections.forEach(section => observer.observe(section));
		}

		updateActiveLink();
		setupScrollSpy();
		window.addEventListener('hashchange', updateActiveLink);
		window.addEventListener('popstate', updateActiveLink);
	});
</script>

<nav
	class={baseClasses.nav}
	role="navigation"
	aria-label="Main Navigation"
	data-testid="mobile-nav-links">
	{
		items.map((key: string) => {
			const item = menu[key as keyof typeof menu];
			if (!item) return null;

			return (
				<a
					href={item.path}
					class={baseClasses.link}
					data-path={item.path}
					aria-label={item.name}
					aria-current={item.path === Astro.url.pathname ? 'page' : undefined}
					data-testid={`nav-link-${item.name.toLowerCase().replace(/ /g, '-')}`}
					data-umami-event="Nav click"
					data-umami-event-section={key}>
					{item.name}
				</a>
			);
		})
	}
</nav>
