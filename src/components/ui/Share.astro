---
import { Icon } from 'astro-icon/components';

const { tweetText, currentUrl } = Astro.props;

const shareLinks = [
	{
		name: 'Twitter',
		icon: 'twitter',
		href: `https://twitter.com/intent/tweet?text=${tweetText}&url=${currentUrl}`,
	},
	{
		name: 'Facebook',
		icon: 'facebook',
		href: `https://www.facebook.com/sharer/sharer.php?u=${currentUrl}`,
	},
	{
		name: 'WhatsApp',
		icon: 'whatsapp',
		href: `https://api.whatsapp.com/send?text=${encodeURIComponent(`${currentUrl}`)}`,
	},
];
---

<div
	class="share-controls flex flex-wrap items-center gap-2 text-lg"
	role="group"
	aria-label="Share on social media">
	<span class="text-base font-bold text-blacktext dark:text-white">Share </span>
	<div class="relative group/tooltip">
		<button
			type="button"
			data-share-copy-url={currentUrl}
			class="inline-flex items-center justify-center size-10 text-blacktext dark:text-white hover:opacity-80 transition-opacity"
			aria-label="Copy link to clipboard">
			<Icon
				name="share"
				aria-hidden="true"
				class="block size-5 shrink-0 [shape-rendering:geometricPrecision]"
			/>
		</button>
		<div
			class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 opacity-0 group-hover/tooltip:opacity-100 transition-opacity duration-200 pointer-events-none z-50">
			<div class="global-tooltip">
				<div class="global-tooltip-content">Copy link</div>
				<div
					class="absolute left-1/2 transform -translate-x-1/2 global-tooltip-arrow global-tooltip-arrow-top">
				</div>
			</div>
		</div>
	</div>
	{
		shareLinks.map(link => (
			<div class="relative group/tooltip">
				<a
					href={link.href}
					class="inline-flex items-center justify-center size-10 text-blacktext dark:text-white hover:opacity-80 transition-opacity"
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`Share on ${link.name}`}>
					<Icon
						name={link.icon}
						aria-hidden="true"
						class="block size-5 shrink-0 [shape-rendering:geometricPrecision]"
					/>
				</a>
				<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 opacity-0 group-hover/tooltip:opacity-100 transition-opacity duration-200 pointer-events-none z-50">
					<div class="global-tooltip">
						<div class="global-tooltip-content">Share on {link.name}</div>
						<div class="absolute left-1/2 transform -translate-x-1/2 global-tooltip-arrow global-tooltip-arrow-top" />
					</div>
				</div>
			</div>
		))
	}
</div>

<script is:inline>
	(function () {
		if (typeof window === 'undefined' || window.__shareCopyUrlInit) return;
		window.__shareCopyUrlInit = true;

		async function copyText(text) {
			if (navigator.clipboard && window.isSecureContext) {
				await navigator.clipboard.writeText(text);
				return true;
			}
			const ta = document.createElement('textarea');
			ta.value = text;
			ta.setAttribute('readonly', '');
			ta.style.position = 'fixed';
			ta.style.left = '-9999px';
			document.body.appendChild(ta);
			ta.select();
			try {
				document.execCommand('copy');
				return true;
			} finally {
				document.body.removeChild(ta);
			}
		}

		function showShareCopyToast() {
			var el = document.getElementById('share-copy-toast');
			if (!el) {
				el = document.createElement('div');
				el.id = 'share-copy-toast';
				el.setAttribute('role', 'status');
				el.setAttribute('aria-live', 'polite');
				el.className =
					'fixed bottom-8 left-1/2 z-[9999] -translate-x-1/2 rounded-lg border border-neutral-200 bg-white px-4 py-2.5 text-sm font-medium text-blacktext shadow-lg dark:border-zinc-700 dark:bg-zinc-900 dark:text-theme-50 pointer-events-none transition-opacity duration-200 opacity-0';
				document.body.appendChild(el);
			}
			el.textContent = 'Copied to clipboard';
			el.classList.remove('opacity-0');
			el.classList.add('opacity-100');
			clearTimeout(window.__shareCopyToastTimer);
			window.__shareCopyToastTimer = setTimeout(function () {
				el.classList.remove('opacity-100');
				el.classList.add('opacity-0');
			}, 2500);
		}

		document.addEventListener('click', async function (e) {
			const btn = e.target && e.target.closest('[data-share-copy-url]');
			if (!btn || btn.tagName !== 'BUTTON') return;
			const url = btn.getAttribute('data-share-copy-url');
			if (!url) return;
			e.preventDefault();
			e.stopPropagation();
			try {
				await copyText(url);
				showShareCopyToast();
			} catch {
				/* ignore */
			}
		});
	})();
</script>
