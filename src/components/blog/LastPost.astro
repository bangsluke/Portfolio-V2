---
import { getCollection } from 'astro:content';
import {
	extractNameFromFilename,
	nameToSlug,
} from '../../utils/filename-utils';
import { getProjectCount } from '../../utils/project-count-utils';
import SkillPill from '../ui/SkillPill.astro';
import ReadMore from '../ui/ReadMore.astro';
import DatePub from './DatePub.astro';

const allPosts = await import.meta.glob('../../pages/blog/posts/*.md', {
	eager: true,
});
const posts = Object.values(allPosts);

const skills = await getCollection('skills');
const projects = await getCollection('projects');

const latestPost: any = posts.reduce((latest: any, current: any) => {
	const latestDate = new Date(latest.frontmatter.pubDate).getTime();
	const currentDate = new Date(current.frontmatter.pubDate).getTime();
	return currentDate > latestDate ? current : latest;
});

const fm = latestPost.frontmatter;
const topics: string[] = [
	...new Set([
		...(fm.topics ?? []),
		...(fm.tags ?? []),
		...(fm.languages ?? []),
	]),
];
const image = fm.image.url;
const imageAlt = fm.image.alt || fm.title;

function deriveBlogSlugFromPostModule(post: any): string {
	const fmSlug = post?.frontmatter?.slug;
	if (typeof fmSlug === 'string' && fmSlug.trim().length > 0) return fmSlug;

	const name = extractNameFromFilename(post?.id ?? '');
	const remainder = /^\d{8}\s+/.test(name) ? name.slice(9) : name;
	return nameToSlug(remainder);
}

function getCanonicalBlogPostUrl(post: any): string {
	return `/blog/posts/${deriveBlogSlugFromPostModule(post)}`;
}

function findSkill(topicName: string) {
	return skills.find(s => {
		const sName = s.data.name || extractNameFromFilename(s.id);
		return sName.toLowerCase() === topicName.toLowerCase();
	});
}
---

{
	latestPost && (
		<div
			style={{ backgroundImage: `url(${image})` }}
			class="h-full border-2 border-theme-300 dark:border-theme-600 flex flex-col overflow-hidden rounded-2xl bg-linear-to-br bg-center bg-cover transition-all ease-in-out duration-200"
			role="article"
			aria-labelledby="post-title">
			<article class="h-full flex flex-col justify-between max-sm:bg-zinc-900 max-sm:relative sm:bg-linear-to-t from-black/95 from-25% to-transparent max-sm:from-60% p-8 max-md:p-6 max-sm:mp-0 max-sm:p-0">
				<a
					href=""
					class="sm:hidden relative top-0 left-0 w-full h-auto -z-0"
					aria-hidden="true">
					<img
						src={image}
						alt={imageAlt}
						class="w-full h-auto"
						loading="lazy"
					/>
				</a>
				<div
					class="w-full flex pb-5 gap-2 flex-wrap justify-end z-10 max-sm:px-6 max-sm:pt-6"
					role="list"
					aria-label="Topics">
					{topics.map(topic => {
						const skill = findSkill(topic);
						const skillName = skill
							? skill.data.name || extractNameFromFilename(skill.id)
							: topic;
						const description =
							(skill?.data as { skillDescription?: string })
								?.skillDescription ?? '';
						const filename = skill
							? extractNameFromFilename(skill.id)
							: topic;
						const count = skill
							? getProjectCount(skillName, filename, projects)
							: 0;

						return (
							<div
								class="relative skill-tooltip-trigger"
								data-skill-name={skillName}
								data-skill-description={description}
								data-skill-count={count}>
								<SkillPill
									skillName={topic}
									size="sm"
									variant="theme"
									className="cursor-default"
									projects={projects}
									disableTooltip={true}
								/>
							</div>
						);
					})}
				</div>

				<a
					href={getCanonicalBlogPostUrl(latestPost)}
					class="text-theme-50 gap-3 h-full flex items-end max-sm:px-6 rounded-lg transition-all"
					aria-label={`Read article: ${latestPost.frontmatter.title}`}>
					<div class="gap-3 flex flex-col justify-end drop-shadow-[1px_6px_1px_rgba(0,0,0,0.3)]">
						<DatePub
							date={latestPost.frontmatter.pubDate}
							class="text-theme-50"
						/>
						<h2
							id="post-title"
							class="text-4xl max-xl:text-3xl max-sm:text-2xl font-bold">
							<span>{latestPost.frontmatter.title}</span>
						</h2>
					</div>
				</a>

				<div class="flex items-end justify-end max-sm:px-6 max-sm:pb-6 mt-3">
					<a href={getCanonicalBlogPostUrl(latestPost)} class="shrink-0">
						<ReadMore class="text-theme-50" />
					</a>
				</div>
			</article>
		</div>
	)
}
