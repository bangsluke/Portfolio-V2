---
// @ts-expect-error - AstroError is not typed
import { AstroError } from 'astro/errors';
import { getCollection } from 'astro:content';
import {
	getHeroDescription,
	getPortfolioConfig,
	processContent,
} from '../../utils/content-processor';
import Button from '../ui/Button.astro';

const [staticData] = await getCollection('staticData');

if (!staticData) {
	throw new AstroError('JSON data not found');
}

// Get the hero description from the Portfolio Site V2 markdown file
const heroDescription = await getHeroDescription();

// Get portfolio configuration options
const portfolioConfig = await getPortfolioConfig();
---

<section
	class="main-section pt-8 pb-12 md:pt-12"
	id="home"
	aria-label="Professional profile and introduction">
	<div
		class="relative mx-auto mb-4 h-96 w-full max-w-7xl rounded-2xl max-md:h-auto bg-linear-to-r from-theme-300 dark:from-theme-600 to-theme-200 dark:to-theme-200/8 hover:to-theme-300/30 dark:hover:to-theme-600/30 p-[.2rem] transition-all hover:shadow-[0_20px_50px_var(--color-theme-500-rgba-04)] dark:before:bg-[radial-gradient(circle,var(--color-theme-500)_0,var(--color-theme-950)_100%)] before:bg-[radial-gradient(circle,var(--color-theme-300)_0,var(--color-theme-200)_100%)] before:absolute before:left-1/2 before:bottom-30 before:h-[30%] before:aspect-square before:rounded-full before:blur-3xl before:opacity-0 dark:before:opacity-70 before:transition before:-z-0 hover:before:animate-pulse xl:before:bottom-2/5">
		<div
			class="group relative z-10 flex h-full items-center justify-center gap-8 overflow-hidden rounded-2xl bg-linear-to-tr from-theme-300 to-white p-4 transition-all hover:shadow-[0_10px_50px_var(--color-theme-500-rgba-02)] dark:bg-linear-to-r dark:from-theme-950 dark:to-zinc-950 dark:overflow-hidden max-md:w-full max-md:gap-3 max-lg:gap-2 max-sm:flex-col">
			<div class="aspect-square h-4/5 max-md:size-32">
				<div
					class="group-hover:scale-105 relative z-20 flex w-full cursor-pointer items-center overflow-hidden rounded-full border border-[color:var(--color-theme-400)] shadow-md transition-all duration-500">
					<div class="relative z-30 flex w-full rounded-full bg-theme-900">
						<div
							class="w-full aspect-square rounded-full bg-center bg-cover brightness-120 dark:brightness-100"
							style={`background-image: url(${staticData.data.profileImage})`}
							aria-label={staticData.data.profileAlt}
							data-testid="profile-picture">
							<a
								href={staticData.data.profileLink}
								class="flex h-full w-full"
								aria-label="View about me page"></a>
						</div>
					</div>
				</div>
			</div>

			<div
				class="flex h-full w-7/12 flex-col justify-center gap-4 p-4 max-md:w-full max-md:gap-2">
				{
					portfolioConfig.lookingForWork && (
						<span class="relative inline-flex items-center mb-2 md:mb-0 text-xs font-semibold leading-0 text-colour dark:text-zinc-300 max-md:font-medium max-sm:justify-center">
							<span class="before:mr-2 before:block before:h-1.5 before:w-1.5 before:rounded-full before:bg-green-400 before:shadow-[0px_0px_0px_3px_var(--color-theme-400-rgba-03)] before:animate-pulse before:content-['']" />
							Available for work
						</span>
					)
				}

				<h1
					data-testid="profile-name"
					class="text-4xl font-black mb-2 md:mb-0 leading-none text-colour dark:text-zinc-300 max-xl:text-3xl max-lg:text-2xl max-sm:text-center">
					{staticData.data.profileName} 👋
				</h1>

				<p
					data-testid="profile-description"
					class="mb-2 md:mb-0 text-lg font-semibold leading-6 md:leading-8 text-colour dark:text-zinc-300 max-xl:text-base"
					set:html={processContent(heroDescription)}
				/>

				<div
					class="flex gap-4 max-sm:flex-row max-sm:items-center max-sm:justify-center max-sm:gap-2">
					<Button
						link={staticData.data.profileLink}
						text="About Me"
						iconName="person"
						variant="dark"
					/>
					<Button
						link={'mailto:' + staticData.data.email}
						text={staticData.data.contactSectionButtonText}
						iconName={staticData.data.emailIconName}
						variant="big"
						data-testid="contact-me-button-top-section"
					/>
				</div>
			</div>
		</div>
	</div>
</section>
